{
  "name": "inform7-wasm",
  "version": "0.1.0",
  "description": "Inform 7 toolchain as WASM modules — compile .ni stories to playable .gblorb files in Node.js, Deno, and the browser",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "copy-wasm": "cp ../../build/*.wasm assets/",
    "copy-inform7-internal": "cp -r ../../build/Internal assets/inform7-internal/",
    "generate-inform7-internal": "node scripts/generate-inform7-internal.mjs",
    "prepare-assets": "pnpm copy-wasm && pnpm copy-inform7-internal && pnpm generate-inform7-internal"
  },
  "keywords": [
    "inform7",
    "interactive-fiction",
    "wasm",
    "wasi",
    "glulx"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@bjorn3/browser_wasi_shim": "^0.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.7.0"
  }
}
